# Required
HC_BACKEND_BASE_URL=https://api.holdingcell.example.com
HC_INGEST_API_KEY=replace-with-long-random-secret

# Cowrie log location (Cowrie JSON output file)
HC_COWRIE_LOG_PATH=/home/cowrie/cowrie/var/log/cowrie/cowrie.json

# Forwarder state and dead-letter persistence
HC_STATE_PATH=/var/lib/holding-cell/forwarder-state.json
HC_DEAD_LETTER_PATH=/var/log/holding-cell/dead_letter.jsonl

# Runtime behavior
HC_POLL_INTERVAL_SECONDS=1.0
HC_HEARTBEAT_INTERVAL_SECONDS=300
HC_HEARTBEAT_PROTOCOLS=ssh,telnet
HC_SESSION_IDLE_TIMEOUT_SECONDS=30
HC_SESSION_MAX_DURATION_SECONDS=300
HC_SESSION_MAX_EVENTS=100

# Retry and network controls
HC_REQUEST_TIMEOUT_SECONDS=10
HC_MAX_RETRIES=3
HC_BACKOFF_BASE_SECONDS=2
HC_VERIFY_TLS=true

# Startup behavior
HC_START_FROM_END=true
HC_LOG_LEVEL=INFO
